# Copy this file to terraform.tfvars and replace placeholder values.
project_name       = "azure-ha-demo"
primary_location   = "Central India"
secondary_location = "East US 2"
force_failover_to_secondary = false
enable_fallback_website     = true
dr_data_retention_days      = 30

# Cost-efficient compute defaults:
# - Primary keeps 2 regular instances for resilience.
# - Secondary keeps 1 smaller standby instance and can use Spot for lower cost.
primary_vm_instances       = 2
secondary_vm_instances     = 1
primary_vm_sku             = "Standard_B2s"
secondary_vm_sku           = "Standard_B1ms"
enable_secondary_spot      = true
secondary_spot_max_bid_price = -1
vm_admin_username          = "azureuser"

# AKS defaults (enabled in primary region for cost-efficient container platform).
enable_aks                    = true
aks_region_roles              = ["primary"]
aks_kubernetes_version        = null
aks_private_cluster_enabled   = false
aks_sku_tier                  = "Free"
aks_node_counts               = { primary = 2, secondary = 1 }
aks_node_vm_sizes             = { primary = "Standard_B2s", secondary = "Standard_B2s" }
aks_enable_cluster_autoscaler = true
aks_node_min_counts           = { primary = 1, secondary = 1 }
aks_node_max_counts           = { primary = 4, secondary = 2 }
aks_service_cidrs             = { primary = "10.110.0.0/16", secondary = "10.120.0.0/16" }
aks_dns_service_ips           = { primary = "10.110.0.10", secondary = "10.120.0.10" }

# Security-first defaults:
# - HTTP is open publicly by default for internet-facing apps.
# - SSH is disabled by default; enable only for temporary break-glass.
allowed_http_source_cidrs = ["*"]
enable_ssh_access         = false
allowed_ssh_source_cidrs  = []

# Example: ssh_public_key = "ssh-rsa AAAAB3Nza... user@host"
ssh_public_key = "REPLACE_WITH_YOUR_SSH_PUBLIC_KEY"

tags = {
  environment = "production"
  owner       = "platform-team"
}
